# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class

# C extensions
*.so

# Distribution / packaging
.Python
env/
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
lib/
!frontend/src/lib/
!frontend/src/lib/**
lib64/
parts/
sdist/
var/
*.egg-info/
.installed.cfg
*.egg

# PyInstaller
#  Usually these files are written by a python script from a template
#  before PyInstaller builds the exe, so as to inject date/other infos into it.
*.manifest
*.spec

# Installer logs
debug.log

# Unit test / coverage reports
htmlcov/
.tox/
.nox/
.coverage
.coverage.*
.cache
nosetests.xml
coverage.xml
*.cover
.hypothesis/
.pytest_cache/

# Jupyter Notebook
.ipynb_checkpoints

# pyenv
.python-version

# pipenv
Pipfile.lock

# mypy
.mypy_cache/
.dmypy.json

# VS Code
.vscode/

# Model outputs and data
*.joblib
*.xlsx
output/
BU_Model_2025/output/
ML model/*.png
ML model/*.csv

# Artifact directories (model outputs, figures, metrics)
artifacts/
!artifacts/.gitkeep
!artifacts/paper_figures/
!artifacts/paper_figures/**

# Core dumps (should never be checked in — see commit 0166ff2)
core
core.*

# Large binary outputs
*.nc
*.h5
*.hdf5

# System files
.DS_Store
Thumbs.db

# Local AI-tooling artifacts (intentionally never tracked)
# Keep these on disk for local IDE/agent workflows but out of public history.
.cursor/
AGENTS.md
.claude/

# Research paper drafts and reference PDFs — kept local, not in public history
docs/papers/
docs/nasa_model_references/

# Manuscript-source docs — maintained in the manuscripts repo (strikerdlm/manuscripts, dcs/amhp/)
docs/methods.md
docs/architecture.md
docs/scientific-background.md
docs/publication-roadmap.md
